  },
  "homepage": "https://github.com/magelegal/mage-dataroom-cli#readme",
  "bugs": {
    "url": "https://github.com/magelegal/mage-dataroom-cli/issues"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
