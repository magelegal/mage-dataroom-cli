{
  "name": "@magelegal/cli",
  "version": "0.4.0",
  "description": "Upload and organize a Mage data room from the command line \u2014 built for humans and AI agents.",
  "type": "module",
  "bin": {
    "mage": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
